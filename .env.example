# =====================================================================
# NexHire environment variables — copy to .env and fill in your values
# =====================================================================

# Backend server port (local dev only — Vercel ignores this)
PORT=5001

# Neon PostgreSQL connection string
# Get this from your Neon dashboard: Connection Details → Pooled connection
DB_CONNECTION_STRING="postgresql://USER:PASSWORD@ep-HOST-pooler.REGION.aws.neon.tech/DBNAME?sslmode=require"

# CORS origin (comma-separated list of allowed origins)
# In production on Vercel, set this to your Vercel URL
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Vite client-side env vars (must be prefixed with VITE_)
# Override this only if your API is on a different origin than your frontend
# VITE_API_BASE=https://your-app.vercel.app/api
