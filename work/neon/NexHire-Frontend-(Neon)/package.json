{
    "name": "nexhire-frontend",
    "version": "1.0.0",
    "scripts": {
        "dev": "concurrently \"npm run server\" \"npm run client\"",
        "client": "cd client && npm run dev",
        "server": "cd server && npm run dev",
        "build": "cd client && npm run build",
        "start": "cd server && npm start",
        "vercel-build": "cd client && npm install && npm run build"
    },
    "devDependencies": {
        "concurrently": "^8.2.0"
    },
    "dependencies": {
        "axios": "^1.13.5",
        "cors": "^2.8.6",
        "dotenv": "^17.3.1",
        "express": "^5.2.1",
        "multer": "^2.0.2",
        "pdf-parse": "^2.4.5",
        "pg": "^8.20.0"
    },
    "description": "NexHire — AI-powered recruitment platform (Neon PostgreSQL + Vercel-ready)",
    "main": "api/index.js",
    "directories": {
        "doc": "docs"
    },
    "repository": {
        "type": "git",
        "url": "git+https://github.com/nawaf-al-hussain/NexHire.git"
    },
    "keywords": ["recruitment", "neon", "postgresql", "vercel", "react", "express"],
    "author": "",
    "license": "ISC",
    "type": "commonjs",
    "bugs": {
        "url": "https://github.com/nawaf-al-hussain/NexHire/issues"
    },
    "homepage": "https://github.com/nawaf-al-hussain/NexHire#readme"
}
